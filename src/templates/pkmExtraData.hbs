</br>
<div class="col s6 set-detail">
    <div class="card">
        <div class="card-image pkm-image-frame">
            <img class="pkm-image" src="{{gifUrl}}" alt="{{name}}" />
        </div>
        <div class="card-title black-text">{{name}}</div>
        <div class="card-content">
            <p>Type: {{pokemon.type1}} {{#if pokemon.type1}} / {{pokemon.type2}} {{/if}}</p>
            <p>Usage Rank: #{{usageData.usage}}</p>
            <p>Tier: {{pokemon.tier}}</p>
        </div>
        <div class="card-action">
            <a href="https://www.smogon.com/dex/ss/pokemon/{{safePkmName name}}/" target="_blank">See more on Smogon Dex</a>
        </div>
    </div>
</div>

<div class="col s6 set-detail">
    <strong class="detail-section-title detail-section-title-stats">Base Stats</strong>
    <table class="PokemonStats">
        <tbody>
            <tr>
                <th>HP:</th>
                <td>{{pokemon.baseStats.hp}}</td>
                <td>
                    <div class="PokemonStats-bar-track">
                        <div class="PokemonStats-bar"
                            style="width:{{statsBarWidth pokemon.baseStats.hp}}%;background-color:{{statsBarColor pokemon.baseStats.hp}};"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <th>Attack:</th>
                <td>{{pokemon.baseStats.atk}}</td>
                <td>
                    <div class="PokemonStats-bar-track">
                        <div class="PokemonStats-bar"
                            style="width:{{statsBarWidth pokemon.baseStats.atk}}%;background-color:{{statsBarColor pokemon.baseStats.atk}};"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <th>Defense:</th>
                <td>{{pokemon.baseStats.def}}</td>
                <td>
                    <div class="PokemonStats-bar-track">
                        <div class="PokemonStats-bar"
                            style="width:{{statsBarWidth pokemon.baseStats.def}}%;background-color:{{statsBarColor pokemon.baseStats.def}};"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <th>Sp. Atk:</th>
                <td>{{pokemon.baseStats.spA}}</td>
                <td>
                    <div class="PokemonStats-bar-track">
                        <div class="PokemonStats-bar"
                            style="width:{{statsBarWidth pokemon.baseStats.spA}}%;background-color:{{statsBarColor pokemon.baseStats.spA}};"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <th>Sp. Def:</th>
                <td>{{pokemon.baseStats.spD}}</td>
                <td>
                    <div class="PokemonStats-bar-track">
                        <div class="PokemonStats-bar"
                            style="width:{{statsBarWidth pokemon.baseStats.spD}}%;background-color:{{statsBarColor pokemon.baseStats.spD}};"></div>
                    </div>
                </td>
            </tr>
            <tr>
                <th>Speed:</th>
                <td>{{pokemon.baseStats.spe}}</td>
                <td>
                    <div class="PokemonStats-bar-track">
                        <div class="PokemonStats-bar"
                            style="width:{{statsBarWidth pokemon.baseStats.spe}}%;background-color:{{statsBarColor pokemon.baseStats.spe}};"></div>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
</div>