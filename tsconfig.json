{
    "compilerOptions": {
        "outDir": "./build/",
        "noImplicitAny": false,
        "module": "commonjs",
        "moduleResolution": "node",
        "target": "es5",
        "lib": ["dom", "es2017"],
        "sourceMap": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "downlevelIteration": true,
        "ignoreDeprecations": "6.0",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts"],
    "exclude": ["build", "node_modules"]
}